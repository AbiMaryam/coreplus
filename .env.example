# CorePlus extension — build-time env vars (Vite injects these at build time)
# Values are NOT secret; they're bundled into the extension and visible to users.
# Real secrets (AutoGoPay API key, Supabase service role key) live ONLY in
# Supabase project secrets and never ship in the extension.

# Supabase project (public anon key is safe to bundle — RLS-protected)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# AutoGoPay public base URL (no API key here — that's server-side only)
VITE_AUTOGOPAY_PUBLIC_BASE=https://autogopay.site
