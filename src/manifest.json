{
  "manifest_version": 3,
  "name": "CorePlus",
  "version": "3.0",
  "description": "Extends multi-period filtering beyond the default and adds sequential bulk-crediting features to the Coretax portal.",
  "icons": {
    "16": "src/assets/icon-16.png",
    "32": "src/assets/icon-32.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "32": "src/assets/icon-32.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    },
    "default_title": "CorePlus"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://coretaxdjp.pajak.go.id/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://coretaxdjp.pajak.go.id/*"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["*://coretaxdjp.pajak.go.id/*"],
      "use_dynamic_url": false
    }
  ]
}
